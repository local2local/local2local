{
  "name": "L2LAAF Autonomous Orchestrator (PROD)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "agent-bus-prod",
        "options": {}
      },
      "id": "bus-trigger-prod",
      "name": "Agent Bus Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [100, 400],
      "webhookId": "agent-bus-prod-hook"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"contents\": [{ \"parts\": [{ \"text\": \"Audit PROD change: Path: {{ $json.body.payload.manifest.targetPath }}. Identify high-impact risks for production.\" }] }] }",
        "options": {}
      },
      "id": "validator-agent-prod",
      "name": "Validator Agent (HTTP)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [300, 400],
      "credentials": {
        "httpHeaderAuth": { "id": "Gemini API Key", "name": "Gemini API Key" }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://chat.googleapis.com/v1/spaces/AAQAQxcghNA/messages",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"text\": \"🚨 **PRODUCTION PROPOSAL: {{ $node['Agent Bus Trigger'].json.body.payload.manifest.targetPath }}**\\n\\n🛡️ **AUDIT:** {{ $node['Validator Agent (HTTP)'].json.candidates[0].content.parts[0].text }}\" }",
        "options": {}
      },
      "id": "chat-notify-prod",
      "name": "Google Chat Card",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [600, 400]
    }
  ],
  "connections": {
    "Agent Bus Trigger": { "main": [[{ "node": "validator-agent-prod", "type": "main", "index": 0 }]] },
    "validator-agent-prod": { "main": [[{ "node": "chat-notify-prod", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1", "saveExecutionProgress": true }
}