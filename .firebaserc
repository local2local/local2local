{
  "projects": {
    "default": "local2local-dev",
    "develop": "local2local-dev",
    "staging": "local2local-staging",
    "production": "local2local-prod"
  },
  "targets": {
    "local2local-dev": {
      "hosting": {
        "command-center": [
          "local2local-dev"
        ]
      }
    },
    "local2local-staging": {
      "hosting": {
        "command-center": [
          "local2local-staging"
        ]
      }
    },
    "local2local-prod": {
      "hosting": {
        "command-center": [
          "local2local-prod"
        ]
      }
    }
  }
}
